<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="SR_DMG.Source.UI.Pages" x:Class="SR_DMG.MainWindow"
    WindowStartupLocation="CenterScreen" Title="Star Rail Damage Calculator"
    Height="700" Width="1050" ResizeMode="CanMinimize">
    <Window.Background>
        <ImageBrush ImageSource="{StaticResource Icon_Backgroup}"/>
    </Window.Background>
    <Grid>
        <Frame Source="{StaticResource TogetherPage}"/>
        <Frame Source="{StaticResource ProgressPage}"/>
    </Grid>
</Window>