<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG"
    xmlns:UI="clr-namespace:SR_DMG.Source.UI" x:Class="SR_DMG.MainWindow"
    xmlns:Icon="/Resources/UI/Icon"
    Title="Star Rail Damage Calculator" Height="615" Width="960"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanMinimize">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Margin="25,10,0,0">
                <UI:ImageSpan Text="未选择" Icon="/Resources/UI/Icon/Item-None.png">
                    <UI:ImageSpan.Images>
                        <Image Source="{DynamicResource Icon_Role-Type-0}"/>
                        <Image Source="{DynamicResource Icon_Element-0}"/>
                    </UI:ImageSpan.Images>
                </UI:ImageSpan>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <StackPanel Orientation="Vertical">
                    <UI:LabelTextBox Label="攻击力" Text="0" Image="{StaticResource Icon_ATK}"/>
                    <UI:LabelTextBox Label="生命值" Text="0" Image="{StaticResource Icon_HP}"/>
                    <UI:LabelTextBox Label="防御力" Text="0" Image="{StaticResource Icon_DEF}"/>
                    <UI:LabelTextBox Label="速度" Text="0" Image="{StaticResource Icon_SPD}"/>
                    <UI:LabelTextBox Label="暴击率" Text="0" Unit="%" Margin="0,10,0,0" Image="{StaticResource Icon_CRIT-Rate}"/>
                    <UI:LabelTextBox Label="暴击伤害" Text="0" Unit="%" Image="{StaticResource Icon_CRIT-DMG}"/>
                    <UI:LabelTextBox Label="伤害提高" Text="0" Unit="%" Image="{DynamicResource Icon_DMG-Boost-0}"/>
                    <UI:LabelTextBox Label="无视防御" Text="0" Unit="%" Image="{StaticResource Icon_DEF}"/>
                    <UI:LabelTextBox Label="抗性穿透" Text="0" Unit="%" Image="{DynamicResource Icon_RES-0}"/>
                    <UI:LabelTextBox Label="效果命中" Text="0" Unit="%" Margin="0,10,0,0" Image="{StaticResource Icon_Effect-Rate}"/>
                    <UI:LabelTextBox Label="治疗提高" Text="0" Unit="%" Image="{StaticResource Icon_Heal-Rate}"/>
                    <UI:LabelTextBox Label="特殊数值" Text="0" Image="{StaticResource Icon_Energy-Toplimit}"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                    <UI:LabelTextBox Label="基础攻击" Text="0" Image="{StaticResource Icon_ATK}"/>
                    <UI:LabelTextBox Label="基础生命" Text="0" Image="{StaticResource Icon_HP}"/>
                    <UI:LabelTextBox Label="基础防御" Text="0" Image="{StaticResource Icon_DEF}"/>
                    <UI:LabelTextBox Label="基础速度" Text="0" Image="{StaticResource Icon_SPD}"/>
                    <UI:LabelTextBox Label="超击破" Text="0" Unit="%" Margin="0,10,0,0" Image="{StaticResource Icon_Break-Effect}"/>
                    <UI:LabelTextBox Label="击破特攻" Text="0" Unit="%" Image="{StaticResource Icon_Break-Effect}"/>
                    <UI:LabelTextBox Label="击破增伤" Text="0" Unit="%" Image="{DynamicResource Icon_DMG-Boost-0}"/>
                    <UI:LabelTextBox Label="击破效率" Text="0" Unit="%" Image="{StaticResource Icon_Break-Effect}"/>
                    <UI:LabelTextBox Label="削韧值" Text="0" Image="{StaticResource Icon_Energy-Toplimit}"/>
                    <UI:LabelTextBox Label="效果抵抗" Text="0" Unit="%" Margin="0,10,0,0" Image="{StaticResource Icon_Effect-RES}"/>
                    <UI:LabelTextBox Label="充能效率" Text="0" Unit="%" Image="{StaticResource Icon_Energy-Rate}"/>
                    <UI:LabelTextBox Label="能量上限" Text="0" Image="{StaticResource Icon_Energy-Toplimit}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>