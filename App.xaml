<Application x:Class="SR_DMG.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=netstandard"
    xmlns:local="clr-namespace:SR_DMG"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DefaultStyle.xaml"/>
                <ResourceDictionary Source="/Themes/LabelTextBox.xaml"/>
                <ResourceDictionary Source="/Themes/IconImages.xaml"/>
                <ResourceDictionary Source="/Themes/ImageSpan.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>