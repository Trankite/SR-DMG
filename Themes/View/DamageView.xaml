<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.Model">
    <Style TargetType="{x:Type local:DamageView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DamageView}">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <StackPanel Orientation="Vertical">
                            <local:DamageItem Title="基础值" Value="{Binding Damage.Base,RelativeSource={RelativeSource TemplatedParent}}"/>
                            <local:DamageItem Title="暴击" Margin="0,10,0,10" Value="{Binding Damage.Crit,RelativeSource={RelativeSource TemplatedParent}}"/>
                            <local:DamageItem Title="期望值" Value="{Binding Damage.Expect,RelativeSource={RelativeSource TemplatedParent}}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                            <local:DamageItem Title="超击破" Value="{Binding Damage.Base,RelativeSource={RelativeSource TemplatedParent}}"/>
                            <local:DamageItem Title="击破" Margin="0,10,0,10" Value="{Binding Damage.Crit,RelativeSource={RelativeSource TemplatedParent}}"/>
                            <local:DamageItem Title="裂伤" Value="{Binding Damage.Expect,RelativeSource={RelativeSource TemplatedParent}}"/>
                        </StackPanel>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>