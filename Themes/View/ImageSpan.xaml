<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.View">
    <Style TargetType="{x:Type local:ImageSpan}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ImageSpan}">
                    <Border CornerRadius="10" Background="{StaticResource BackBrush}" Width="100" Height="150">
                        <StackPanel Orientation="Vertical">
                            <Image Source="{TemplateBinding Icon}" Width="100" Height="100">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,100,100" RadiusX="10" RadiusY="10"/>
                                </Image.Clip>
                            </Image>
                            <ItemsControl ItemsSource="{TemplateBinding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" Height="20" Width="80" Margin="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                                <TextBlock
                                    Text="{TemplateBinding Text}" Foreground="{StaticResource ForeBrush}"
                                    FontWeight="{StaticResource FontWeigh}" FontSize="{StaticResource FontSize}"
                                    TextAlignment="Center" Width="80" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="{TemplateBinding Text}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>