<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.Model">
    <Style TargetType="{x:Type local:ComplexTicker}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ComplexTicker}">
                    <StackPanel Orientation="Horizontal" Height="20">
                        <Button
                            Background="{DynamicResource BackBrush}"
                            BorderBrush="{DynamicResource BackBrush}"
                            Width="20" Height="20">
                            <Button.InputBindings>
                                <MouseBinding
                                Gesture="LeftClick"
                                Command="{Binding Event.TickChanged,RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Button.InputBindings>
                            <Image>
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="{DynamicResource Icon_Not_Selected}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Flag,RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Source" Value="{DynamicResource Icon_Selected}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Button>
                        <TextBlock
                            Text="{Binding Text,RelativeSource={RelativeSource TemplatedParent}}"
                            Foreground="{DynamicResource ForeBrush}" Margin="5,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text,RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>