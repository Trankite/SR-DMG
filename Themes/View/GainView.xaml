<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.View">
    <Style TargetType="{x:Type local:GainView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:GainView}">
                    <Grid>
                        <local:PlexScroll
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden" Height="150">
                            <local:GainItem Model="{Binding Model.Select,RelativeSource={RelativeSource TemplatedParent}}">
                                <local:GainItem.InputBindings>
                                    <MouseBinding
                                        MouseAction="LeftClick"
                                        Command="{Binding Event.SelectItem_Click,RelativeSource={RelativeSource TemplatedParent}}"
                                        CommandParameter="{Binding Model,RelativeSource={RelativeSource TemplatedParent}}"/>
                                </local:GainItem.InputBindings>
                            </local:GainItem>
                        </local:PlexScroll>
                        <Popup
                            IsOpen="{Binding Model.Dropdown,RelativeSource={RelativeSource TemplatedParent},Mode=TwoWay}"
                            AllowsTransparency="True" StaysOpen="False" Placement="Center" PopupAnimation="Fade">
                            <Border CornerRadius="20" Background="{StaticResource BackBrush_Minor}">
                                <local:PlexScroll
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden"
                                    MaxHeight="300" Margin="0,10,0,10">
                                    <ItemsControl Margin="10" ItemsSource="{Binding Model.Items,RelativeSource={RelativeSource TemplatedParent}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <local:GainItem Model="{Binding}" Margin="5">
                                                    <local:GainItem.InputBindings>
                                                        <MouseBinding
                                                            MouseAction="LeftClick"
                                                            Command="{Binding Event.GainItem_Click,RelativeSource={RelativeSource AncestorType={x:Type local:GainView}}}">
                                                            <MouseBinding.CommandParameter>
                                                                <MultiBinding Converter="{StaticResource MultiValueConverter}">
                                                                    <Binding Path="Model" RelativeSource="{RelativeSource AncestorType={x:Type local:GainView}}"/>
                                                                    <Binding Path="Model" RelativeSource="{RelativeSource AncestorType={x:Type local:GainItem}}"/>
                                                                </MultiBinding>
                                                            </MouseBinding.CommandParameter>
                                                        </MouseBinding>
                                                    </local:GainItem.InputBindings>
                                                </local:GainItem>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </local:PlexScroll>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>