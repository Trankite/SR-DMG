<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.Model">
    <Style TargetType="{x:Type local:GainView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:GainView}">
                    <Grid>
                        <local:GainItem Gain="{TemplateBinding Select}" Height="150">
                            <local:GainItem.InputBindings>
                                <MouseBinding
                                    MouseAction="LeftClick"
                                    Command="{Binding Event.SelectItem_Click,RelativeSource={RelativeSource TemplatedParent}}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"/>
                            </local:GainItem.InputBindings>
                        </local:GainItem>
                        <Popup IsOpen="{Binding IsOpen,RelativeSource={RelativeSource TemplatedParent},Mode=TwoWay}"
                               AllowsTransparency="True" StaysOpen="False" Placement="Center" PopupAnimation="Fade">
                            <Border CornerRadius="20" Background="{DynamicResource BackBrush_Minor}">
                                <local:ComplexScroll
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden"
                                    MaxHeight="300" Margin="0,10,0,10">
                                    <ItemsControl Margin="10" ItemsSource="{TemplateBinding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <local:GainItem Gain="{Binding}" Margin="5">
                                                    <local:GainItem.InputBindings>
                                                        <MouseBinding
                                                            MouseAction="LeftClick"
                                                            Command="{Binding Event.GainItem_Click,RelativeSource={RelativeSource AncestorType={x:Type local:GainView}}}">
                                                            <MouseBinding.CommandParameter>
                                                                <MultiBinding Converter="{StaticResource GainViewConvert}">
                                                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type local:GainView}}"/>
                                                                    <Binding RelativeSource="{RelativeSource AncestorType={x:Type local:GainItem}}"/>
                                                                </MultiBinding>
                                                            </MouseBinding.CommandParameter>
                                                        </MouseBinding>
                                                    </local:GainItem.InputBindings>
                                                </local:GainItem>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </local:ComplexScroll>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>