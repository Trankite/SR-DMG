<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SR_DMG.Source.UI.Model">
    <Style TargetType="{x:Type local:LabelTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LabelTextBox}">
                    <Border CornerRadius="15" Background="{DynamicResource BackBrush}" Margin="0,0,0,5">
                        <Grid Width="200" Height="30">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ForeBrush}"/>
                                    <Setter Property="FontWeight" Value="{DynamicResource FontWeigh}"/>
                                    <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </Grid.Resources>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Image Source="{TemplateBinding Image}" Width="30" Height="30"/>
                                <TextBlock Text="{TemplateBinding Title}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox
                                    Text="{TemplateBinding Text}"
                                    Foreground="{DynamicResource ForeBrush}"
                                    Background="{DynamicResource BackBrush}"
                                    BorderBrush="{DynamicResource BackBrush}"
                                    FontWeight="{DynamicResource FontWeigh}"
                                    FontSize="{DynamicResource FontSize}"
                                    TextAlignment="Right" Width="65"
                                    VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Unit}" Width="15" Margin="5,0,10,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>