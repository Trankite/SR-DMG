<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=netstandard">
    <FontWeight x:Key="FontWeigh">Bold</FontWeight>
    <system:Double x:Key="Opacity">0.95</system:Double>
    <system:Double x:Key="FontSize">15</system:Double>
    <system:Double x:Key="FontSize_Big">20</system:Double>
    <SolidColorBrush x:Key="BackBrush" Color="#323232"/>
    <SolidColorBrush x:Key="BackBrush_Minor" Color="#505050"/>
    <SolidColorBrush x:Key="ForeBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighBrush" Color="#FAC864"/>
    <SolidColorBrush x:Key="PlusBrush" Color="#32FA32"/>
    <SolidColorBrush x:Key="MinuBrush" Color="#FA3232"/>
    <Style TargetType="Border">
        <Setter Property="Opacity" Value="{StaticResource Opacity}"/>
    </Style>
    <Style TargetType="Image">
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{StaticResource ForeBrush}"/>
        <Setter Property="Background" Value="{StaticResource BackBrush_Minor}"/>
    </Style>
    <ControlTemplate x:Key="TextBoxSelected" TargetType="TextBox">
        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
            <ScrollViewer x:Name="PART_ContentHost"/>
        </Border>
    </ControlTemplate>
</ResourceDictionary>