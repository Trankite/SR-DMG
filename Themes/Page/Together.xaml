<Page
    x:Class="SR_DMG.Source.UI.Pages.Together"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:Model="clr-namespace:SR_DMG.Source.UI.Model"
    xmlns:View="clr-namespace:SR_DMG.Source.UI.View"
    mc:Ignorable="d" d:DesignHeight="680" d:DesignWidth="1020">
    <Page.DataContext>
        <Model:Together/>
    </Page.DataContext>
    <Grid Margin="0,10,0,10">
        <Grid.Background>
            <ImageBrush ImageSource="{Binding Icon,Converter={StaticResource SourceConverter}}" Stretch="Uniform"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <DockPanel Grid.Column="1">
            <Border CornerRadius="15" Background="{StaticResource BackBrush_Minor}" DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal" Margin="10" Height="150">
                    <View:ImageSpan
                        Text="{Binding Role.Text}"
                        Icon="{Binding Role.Icon,Converter={StaticResource SourceConverter},ConverterParameter={StaticResource Icon_Not_Role}}"
                        Tags="{Binding Role.Tags,Converter={StaticResource SourceConverter}}"/>
                    <View:GainView Model="{Binding Skills}" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="0" Title="攻击力" Image="{StaticResource Icon_ATK}"
                    Text="{Binding Roleus.ATK,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="1" Title="生命值" Image="{StaticResource Icon_HP}"
                    Text="{Binding Roleus.HP,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="2" Title="防御力" Image="{StaticResource Icon_DEF}"
                    Text="{Binding Roleus.DEF,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="3" Title="速度" Image="{StaticResource Icon_SPD}"
                    Text="{Binding Roleus.SPD,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="5" Title="暴击率" Unit="%" Image="{StaticResource Icon_CRIT_Rate}"
                    Text="{Binding Roleus.CRIT_Rate,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="6" Title="暴击伤害" Unit="%" Image="{StaticResource Icon_CRIT_DMG}"
                    Text="{Binding Roleus.CRIT_DMG,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="7" Title="伤害提高" Unit="%"
                    Image="{Binding Roleus.Break_Element,Converter={StaticResource ElementConverter},ConverterParameter='Icon_DMG_Boost'}"
                    Text="{Binding Roleus.DMG_Boost,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="8" Title="无视防御" Unit="%" Image="{StaticResource Icon_DEF}"
                    Text="{Binding Roleus.DEF_Reduced,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="9" Title="抗性穿透" Unit="%"
                    Image="{Binding Roleus.Break_Element,Converter={StaticResource ElementConverter},ConverterParameter='Icon_RES'}"
                    Text="{Binding Roleus.RES_Reduced,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="11" Title="效果命中" Unit="%" Image="{StaticResource Icon_Effect_Rate}"
                    Text="{Binding Roleus.Effect_Rate,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="12" Title="治疗提高" Unit="%" Image="{StaticResource Icon_Heal_Rate}"
                    Text="{Binding Roleus.Heal_Rate,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="0" Grid.Row="13" Title="特殊数值" Image="{StaticResource Icon_Energy_Toplimit}"
                    Text="{Binding Roleus.Accumulate,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="0" Title="基础攻击" Image="{StaticResource Icon_ATK}"
                    Text="{Binding Roleus.ATK_Base,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="1" Title="基础生命" Image="{StaticResource Icon_HP}"
                    Text="{Binding Roleus.HP_Base,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="2" Title="基础防御" Image="{StaticResource Icon_DEF}"
                    Text="{Binding Roleus.DEF_Base,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="3" Title="基础速度" Image="{StaticResource Icon_SPD}"
                    Text="{Binding Roleus.SPD_Base,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="5" Title="超击破" Unit="%" Image="{StaticResource Icon_Break_Effect}"
                    Text="{Binding Roleus.Break_Equal,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="6" Title="击破特攻" Unit="%" Image="{StaticResource Icon_Break_Effect}"
                    Text="{Binding Roleus.Break_Effect,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="7" Title="击破增伤" Unit="%"
                    Image="{Binding Roleus.Break_Element,Converter={StaticResource ElementConverter},ConverterParameter='Icon_DMG_Boost'}"
                    Text="{Binding Roleus.Break_Boost,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="8" Title="击破效率" Unit="%" Image="{StaticResource Icon_Break_Effect}"
                    Text="{Binding Roleus.Break_Efficiency,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="9" Title="削韧值" Image="{StaticResource Icon_Energy_Toplimit}"
                    Text="{Binding Roleus.Toughness_Reduced,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="11" Title="效果抵抗" Unit="%" Image="{StaticResource Icon_Effect_Rest}"
                    Text="{Binding Roleus.Effect_Rest,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="12" Title="充能效率" Unit="%" Image="{StaticResource Icon_Energy_Rate}"
                    Text="{Binding Roleus.Energy_Rate,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                <View:LabelTextBox
                    Grid.Column="1" Grid.Row="13" Title="能量上限" Image="{StaticResource Icon_Energy_Toplimit}"
                    Text="{Binding Roleus.Energy_Toplimit,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
            </Grid>
        </DockPanel>
        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Column="0" Grid.Row="0" CornerRadius="15" Background="{StaticResource BackBrush_Minor}">
                <StackPanel Orientation="Horizontal" Margin="10">
                    <View:ImageSpan
                        Text="{Binding Equip.Text}" Tags="{Binding Equip.Tags,Converter={StaticResource SourceConverter}}"
                        Icon="{Binding Equip.Icon,Converter={StaticResource SourceConverter},ConverterParameter={StaticResource Icon_Not_Role}}"/>
                    <View:GainView Model="{Binding Gains}" Margin="10,0,10,0"/>
                    <Border CornerRadius="15" Background="{StaticResource BackBrush}">
                        <UniformGrid Columns="1" Margin="10">
                            <View:PlexTicker Text="重置面板" Flag="{Binding NoGain,Mode=TwoWay}"/>
                            <View:PlexTicker Text="禁止修改" Flag="{Binding NoModify,Mode=TwoWay}"/>
                            <View:PlexTicker Text="比较伤害" Flag="{Binding Comparing,Mode=TwoWay}"/>
                            <View:PlexTicker Text="等待保存" Flag="{Binding UnSaved,Mode=TwoWay}"/>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>
            <View:DamageView
                Grid.Column="0" Grid.Row="1" Damage="{Binding Damage}" Compare="{Binding Compare}"
                Breaker="{Binding Roleus.Break_Element,Converter={StaticResource BreakerConverter}}"/>
            <View:Equation Grid.Column="0" Grid.Row="2" Margin="0,0,0,10" Model="{Binding Equation}"/>
            <Border Grid.Column="0" Grid.Row="3" CornerRadius="15" Background="{StaticResource BackBrush_Minor}">
                <DockPanel Margin="10">
                    <View:ImageSpan
                        Text="{Binding Enemy.Text}" Tags="{Binding Enemy.Tags,Converter={StaticResource SourceConverter}}"
                        Icon="{Binding Enemy.Icon,Converter={StaticResource SourceConverter},ConverterParameter={StaticResource Icon_Not_Enemy}}"/>
                    <Grid Margin="5,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <View:LabelTextBox
                            Grid.Column="0" Grid.Row="0" Title="角色等级" Unit="级" Image="{StaticResource Icon_HP}"
                            Text="{Binding Roleus.Role_Level,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                        <View:LabelTextBox
                            Grid.Column="0" Grid.Row="1" Title="抗性" Unit="%"
                            Image="{Binding Roleus.Break_Element,Converter={StaticResource ElementConverter},ConverterParameter='Icon_RES'}"
                            Text="{Binding Roleus.RES_Boost,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                        <View:LabelTextBox
                            Grid.Column="0" Grid.Row="2" Title="易伤" Unit="%"
                            Image="{Binding Roleus.Break_Element,Converter={StaticResource ElementConverter},ConverterParameter='Icon_DMG_Boost'}"
                            Text="{Binding Roleus.DMG_Taken,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                        <View:LabelTextBox
                            Grid.Column="1" Grid.Row="0" Title="怪物等级" Unit="级" Image="{StaticResource Icon_HP}"
                            Text="{Binding Roleus.Enemy_Level,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                        <View:LabelTextBox
                            Grid.Column="1" Grid.Row="1" Title="免伤" Unit="%" Image="{StaticResource Icon_DEF}"
                            Text="{Binding Roleus.DMG_Reduction,Converter={StaticResource NumberConverter},ConverterParameter='1',Mode=TwoWay}"/>
                        <View:LabelTextBox
                            Grid.Column="1" Grid.Row="2" Title="韧性值" Image="{StaticResource Icon_Energy_Toplimit}"
                            Text="{Binding Roleus.Toughness,Converter={StaticResource NumberConverter},ConverterParameter='0',Mode=TwoWay}"/>
                        <Border
                            Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" CornerRadius="15"
                            Background="{StaticResource BackBrush}" Height="30">
                            <View:PlexSlider Title="数量" Maximum="5" Value="{Binding Roleus.Enemy_Number,Mode=TwoWay}"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>