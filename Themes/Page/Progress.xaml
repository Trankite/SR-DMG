<Page x:Class="SR_DMG.Source.UI.Pages.Progress"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:Model="clr-namespace:SR_DMG.Source.UI.Model"
      xmlns:View="clr-namespace:SR_DMG.Source.UI.View"
      d:DataContext="{d:DesignInstance Type=Model:Progress}"
      mc:Ignorable="d" d:DesignHeight="680" d:DesignWidth="1020">
    <Border Background="{StaticResource BackBrush_Minor}">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.Dorpdown,RelativeSource={RelativeSource AncestorType=Page}}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border Background="{StaticResource BackBrush}" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="100,20,100,20">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource ForeBrush}"/>
                        <Setter Property="FontSize" Value="{StaticResource FontSize}"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource BackBrush_Minor}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BackBrush_Minor}"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Width" Value="200"/>
                    </Style>
                </StackPanel.Resources>
                <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSize_Big}"/>
                <TextBlock Text="{Binding Text}" Margin="10" TextTrimming="CharacterEllipsis"/>
                <ProgressBar Value="{Binding Value}" Maximum="{Binding Maxmum}" Height="25"/>
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="1" CommandParameter="{Binding}"
                        Command="{Binding Event.Retry_Click,RelativeSource={RelativeSource AncestorType=Page}}">
                        <TextBlock Text="重试"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="3">
                        <TextBlock Text="{Binding Value}"/>
                        <TextBlock Text="/" Margin="5,0,5,0"/>
                        <TextBlock Text="{Binding Maxmum}"/>
                    </StackPanel>
                    <Button
                        Grid.Column="5"
                        Command="{Binding Event.Cancel_Click,RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}">
                        <TextBlock Text="取消"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Border>
</Page>